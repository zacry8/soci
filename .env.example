PORT=8787
APP_BASE_URL=https://soci.hommemade.xyz
API_BASE_URL=https://api.soci.hommemade.xyz

# Comma-separated allowed CORS origins (no trailing slash)
CORS_ORIGINS=https://soci.hommemade.xyz

# Request size limits
MAX_JSON_BYTES=5242880
MAX_UPLOAD_BYTES=12582912

# Auth
AUTH_SECRET=replace-with-a-long-random-string
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-password
ALLOW_SELF_REGISTER=true

# Email (Resend)
EMAIL_ENABLED=false
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=

# Persistence (Docker volume paths — do not change unless you update docker-compose.yml)
DATA_FILE=/data/db.json
UPLOAD_DIR=/uploads

# Backup + durability
BACKUP_DIR=/backups
BACKUP_DATA_FILE=/data/db.json
BACKUP_UPLOAD_DIR=/uploads
BACKUP_MANIFEST_VERSION=1

# Optional post-backup replication hook (example: scp/rsync command)
# POST_BACKUP_HOOK=
